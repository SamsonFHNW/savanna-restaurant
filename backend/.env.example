# ─────────────────────────────────────────────
# Savanna backend — environment variables
# Copy to .env for local dev (never commit .env).
# In production (Render) set these in the dashboard.
# ─────────────────────────────────────────────

# Where reservation/contact notifications are sent
OWNER_EMAIL=owner@example.com

# Resend API key (https://resend.com) — used to deliver all email
RESEND_API_KEY=re_xxxxx

# Verified sender address for the savanna-restaurant.ch domain
FROM_EMAIL=reservations@savanna-restaurant.ch

# Comma-separated CORS allow-list (the frontend origins)
CORS_ORIGINS=http://localhost:3000

# development | production
ENVIRONMENT=development
