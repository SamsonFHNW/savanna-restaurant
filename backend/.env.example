# ─────────────────────────────────────────────
# Savanna backend — environment variables
# Copy to .env for local dev (never commit .env)
# ─────────────────────────────────────────────

# ─── Recipients ───
OWNER_EMAIL=info@savanna-restaurant.ch
OWNER_WHATSAPP=+41791234567          # E.164 format, filled in later

# ─── Email — choose ONE transport ───
# Option A: Resend (recommended, no SMTP setup)
# RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Savanna <reservations@savanna-restaurant.ch>

# Option B: SMTP (e.g. Infomaniak, Gmail app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# ─── WhatsApp via Twilio ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── CORS (comma-separated allowed origins) ───
ALLOWED_ORIGINS=https://savanna-restaurant.ch,https://www.savanna-restaurant.ch,http://localhost:8000

# ─── Rate limiting (optional overrides) ───
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3600
